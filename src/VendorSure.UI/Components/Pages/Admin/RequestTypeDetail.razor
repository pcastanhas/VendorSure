@page "/admin/request-types/{Id:int}"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using VendorSure.Domain.RequestTypes
@using VendorSure.Services.RequestTypes
@using VendorSure.UI.Components.Pages.Admin.RequestTypeTabs

@inject IRequestTypeRepository TypeRepository
@inject IRequestTypeVersionRepository VersionRepository
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject ILogger<RequestTypeDetail> Logger

<PageTitle>@PageTitleText — VendorSure</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
}
else if (_type is null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Request type <code>id=@Id</code> not found.
        <MudLink Href="/admin/request-types">Back to list</MudLink>.
    </MudAlert>
}
else
{
    @* --- Type-level edit surface ---------------------------------- *@
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudStack Spacing="0">
                <MudText Typo="Typo.overline" Class="mud-text-secondary">Request type</MudText>
                <MudText Typo="Typo.h5">
                    @_type.Name
                    @if (!_type.IsActive)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-2" Variant="Variant.Outlined">Inactive</MudChip>
                    }
                </MudText>
            </MudStack>
            <MudSpacer />
            <MudLink Href="/admin/request-types">← Back to list</MudLink>
        </MudStack>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_editedName"
                              Label="Name"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Error="@TypeNameIsInvalid"
                              ErrorText="Name is required."
                              MaxLength="100" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="_editedIsActive" Color="Color.Success">
                    Active
                </MudSwitch>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="_editedIsExplanationRequired" Color="Color.Primary">
                    Explanation required
                </MudSwitch>
            </MudItem>
            <MudItem xs="12" Class="d-flex justify-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveTypeAsync"
                           Disabled="@(TypeNameIsInvalid || _savingType)"
                           StartIcon="@Icons.Material.Filled.Save">
                    Save type
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* --- Version selector & metadata ----------------------------- *@
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        @if (_versions.Count == 0)
        {
            <MudText Class="mud-text-secondary">
                This type has no versions yet. (Unexpected — every type
                should be created with a Draft v1.)
            </MudText>
        }
        else
        {
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudSelect T="int"
                               Value="@_selectedVersionId"
                               ValueChanged="@OnVersionChanged"
                               Label="Version"
                               Variant="Variant.Outlined">
                        @foreach (var v in _versions)
                        {
                            <MudSelectItem T="int" Value="@v.Id">
                                v@(v.Version) — @StateLabel(v.RequestState)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="8">
                    @if (_selectedVersion is not null)
                    {
                        <MudStack Spacing="1">
                            <VersionTimestampLine Label="Created"
                                                  Value="@_selectedVersion.CreatedTs" />
                            <VersionTimestampLine Label="Placed in service"
                                                  Value="@_selectedVersion.PlacedInServiceTs" />
                            <VersionTimestampLine Label="Superseded"
                                                  Value="@_selectedVersion.SupersededTs" />
                        </MudStack>
                    }
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Class="mt-3" Spacing="2">
                <MudSpacer />
                @if (_selectedVersion is not null && _selectedVersion.RequestState == RequestState.Draft)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PublishedWithChanges"
                               OnClick="PlaceInServiceAsync"
                               Disabled="@_transitioning">
                        Place v@(_selectedVersion.Version) in service
                    </MudButton>
                }
                @if (!HasDraft)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.NoteAdd"
                               OnClick="CreateNewDraftAsync"
                               Disabled="@_transitioning">
                        Create new Draft
                    </MudButton>
                }
            </MudStack>

            @if (_selectedVersion is not null && _selectedVersion.RequestState != RequestState.Draft)
            {
                <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
                    Version v@(_selectedVersion.Version) is <strong>@StateLabel(_selectedVersion.RequestState)</strong>
                    and immutable.
                    @if (!HasDraft)
                    {
                        <span>Click <strong>Create new Draft</strong> above to make a v@(_versions.Max(v => v.Version) + 1) Draft for editing.</span>
                    }
                    else
                    {
                        var draft = _versions.First(v => v.RequestState == RequestState.Draft);
                        <span>Switch to v@(draft.Version) (Draft) to edit.</span>
                    }
                </MudAlert>
            }
        }
    </MudPaper>

    @* --- Tabs scaffold (filled in Chunks 6-8 and Phase 5) -------- *@
    <MudPaper Elevation="1">
        <MudTabs Outlined="true" Position="Position.Top" Rounded="true" TabPanelsClass="pa-4">
            <MudTabPanel Text="Workflows" Icon="@Icons.Material.Filled.AccountTree">
                @if (_selectedVersion is not null && _type is not null)
                {
                    <WorkflowsTab VersionId="@_selectedVersion.Id"
                                  IsDraft="@(_selectedVersion.RequestState == RequestState.Draft)"
                                  TypeId="@_type.Id" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                        Select a version to view its workflows.
                    </MudAlert>
                }
            </MudTabPanel>
            <MudTabPanel Text="Required Documents" Icon="@Icons.Material.Filled.Description">
                @if (_selectedVersion is not null)
                {
                    <RequiredDocumentsTab VersionId="@_selectedVersion.Id"
                                          IsDraft="@(_selectedVersion.RequestState == RequestState.Draft)" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                        Select a version to view its required documents.
                    </MudAlert>
                }
            </MudTabPanel>
            <MudTabPanel Text="Validations" Icon="@Icons.Material.Filled.RuleFolder">
                @if (_selectedVersion is not null)
                {
                    <ValidationsTab VersionId="@_selectedVersion.Id"
                                    IsDraft="@(_selectedVersion.RequestState == RequestState.Draft)" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                        Select a version to view its validations.
                    </MudAlert>
                }
            </MudTabPanel>
            <MudTabPanel Text="Selection Prompt" Icon="@Icons.Material.Filled.AltRoute">
                @if (_selectedVersion is not null)
                {
                    <SelectionPromptTab VersionId="@_selectedVersion.Id"
                                        IsDraft="@(_selectedVersion.RequestState == RequestState.Draft)" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                        Select a version to view its selection prompt.
                    </MudAlert>
                }
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
}

@code {
    [Parameter] public int Id { get; set; }

    private RequestType? _type;
    private IReadOnlyList<RequestTypeVersion> _versions = Array.Empty<RequestTypeVersion>();
    private RequestTypeVersion? _selectedVersion;
    private int _selectedVersionId;

    private string _editedName = string.Empty;
    private bool _editedIsActive;
    private bool _editedIsExplanationRequired;

    private bool _loading = true;
    private bool _savingType;
    private bool _transitioning;

    private string PageTitleText => _type is null ? "Request Type" : _type.Name;
    private bool TypeNameIsInvalid => string.IsNullOrWhiteSpace(_editedName);
    private bool HasDraft => _versions.Any(v => v.RequestState == RequestState.Draft);

    protected override async Task OnParametersSetAsync()
    {
        // OnParametersSetAsync fires when the route parameter changes too;
        // re-load if we navigated between two ids in one circuit.
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _type = await TypeRepository.GetByIdAsync(Id);
            if (_type is null)
            {
                _versions = Array.Empty<RequestTypeVersion>();
                _selectedVersion = null;
                _selectedVersionId = 0;
                return;
            }

            // Seed the edit form with the current values.
            _editedName = _type.Name;
            _editedIsActive = _type.IsActive;
            _editedIsExplanationRequired = _type.IsExplanationRequired;

            _versions = await VersionRepository.GetByRequestTypeIdAsync(Id);
            PickDefaultVersion();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load Request Type detail (id={Id}).", Id);
            Snackbar.Add("Failed to load. Check the log.", Severity.Error);
            _type = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private void PickDefaultVersion()
    {
        // Preference order: Draft (highest version number if multiple), then
        // InService, then the most-recent Superseded. The list comes back
        // ascending by version number — easier to reason about iterating
        // in reverse and picking the first match per state.
        var byVersionDesc = _versions.OrderByDescending(v => v.Version).ToList();

        _selectedVersion =
            byVersionDesc.FirstOrDefault(v => v.RequestState == RequestState.Draft)
            ?? byVersionDesc.FirstOrDefault(v => v.RequestState == RequestState.InService)
            ?? byVersionDesc.FirstOrDefault();

        _selectedVersionId = _selectedVersion?.Id ?? 0;
    }

    private void OnVersionChanged(int versionId)
    {
        _selectedVersionId = versionId;
        _selectedVersion = _versions.FirstOrDefault(v => v.Id == versionId);
    }

    private async Task SaveTypeAsync()
    {
        if (_type is null || TypeNameIsInvalid) return;

        _savingType = true;
        try
        {
            var edited = new RequestType
            {
                Id = _type.Id,
                Name = _editedName.Trim(),
                IsExplanationRequired = _editedIsExplanationRequired,
                IsActive = _editedIsActive,
            };
            var result = await TypeRepository.UpdateAsync(edited);
            switch (result)
            {
                case UpdateRequestTypeResult.Updated:
                    Logger.LogInformation("Request type {Id} updated by admin UI.", _type.Id);
                    Snackbar.Add($"Saved {edited.Name}.", Severity.Success);
                    await LoadAsync();
                    break;

                case UpdateRequestTypeResult.NotFound:
                    Logger.LogWarning("UpdateAsync NotFound for request type id={Id}.", _type.Id);
                    Snackbar.Add(
                        $"Could not save — request type no longer exists. Returning to list.",
                        Severity.Warning);
                    Navigation.NavigateTo("/admin/request-types");
                    break;

                case UpdateRequestTypeResult.RejectedNameConflict:
                    Logger.LogWarning(
                        "Update rejected: request type name '{Name}' collides with another row.",
                        edited.Name);
                    Snackbar.Add(
                        $"Cannot save: another request type already has the name '{edited.Name}'.",
                        Severity.Error);
                    break;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save request type id={Id}.", _type.Id);
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingType = false;
        }
    }

    private async Task CreateNewDraftAsync()
    {
        if (_type is null || _transitioning) return;

        _transitioning = true;
        try
        {
            var result = await VersionRepository.CreateDraftAsync(_type.Id);
            switch (result.Outcome)
            {
                case CreateDraftOutcome.Created:
                    Logger.LogInformation(
                        "New Draft v{Version} (id={Id}) created on request type {TypeId}.",
                        result.Version, result.Id, _type.Id);
                    Snackbar.Add($"Created Draft v{result.Version}.", Severity.Success);

                    // Reload then select the freshly-created Draft.
                    await LoadAsync();
                    if (result.Id is int newId)
                    {
                        _selectedVersionId = newId;
                        _selectedVersion = _versions.FirstOrDefault(v => v.Id == newId);
                    }
                    break;

                case CreateDraftOutcome.RejectedRequestTypeNotFound:
                    Snackbar.Add(
                        "Cannot create Draft: request type no longer exists.",
                        Severity.Warning);
                    Navigation.NavigateTo("/admin/request-types");
                    break;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create new Draft on request type id={Id}.", _type.Id);
            Snackbar.Add($"Failed to create Draft: {ex.Message}", Severity.Error);
        }
        finally
        {
            _transitioning = false;
        }
    }

    private async Task PlaceInServiceAsync()
    {
        if (_selectedVersion is null || _transitioning) return;
        if (_selectedVersion.RequestState != RequestState.Draft) return;

        // Confirm — placing in service is the first irreversible transition
        // and supersedes the prior In Service if any. Make sure the admin
        // understands the side-effect.
        var priorInService = _versions.FirstOrDefault(v => v.RequestState == RequestState.InService);
        var priorMessage = priorInService is null
            ? "This will make this version the live one for new submissions."
            : $"This will make this version the live one for new submissions and "
              + $"<strong>supersede v{priorInService.Version}</strong>, which becomes read-only.";

        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: $"Place v{_selectedVersion.Version} in service?",
            markupMessage: new MarkupString(priorMessage),
            yesText: "Place in service",
            cancelText: "Cancel",
            options: new DialogOptions { CloseOnEscapeKey = true });

        if (confirmed != true) return;

        var versionId = _selectedVersion.Id;
        _transitioning = true;
        try
        {
            var result = await VersionRepository.TransitionToInServiceAsync(versionId);
            switch (result.Outcome)
            {
                case TransitionToInServiceOutcome.Succeeded:
                    Logger.LogInformation(
                        "Version id={VersionId} placed in service on request type {TypeId}.",
                        versionId, _type?.Id);
                    Snackbar.Add($"Placed v{_selectedVersion.Version} in service.", Severity.Success);

                    // Reload and keep the same version selected — it's now
                    // In Service rather than Draft.
                    await LoadAsync();
                    _selectedVersionId = versionId;
                    _selectedVersion = _versions.FirstOrDefault(v => v.Id == versionId);
                    break;

                case TransitionToInServiceOutcome.NotFound:
                    Snackbar.Add(
                        "Cannot place in service: version no longer exists.",
                        Severity.Warning);
                    await LoadAsync();
                    break;

                case TransitionToInServiceOutcome.RejectedNotDraft:
                    Snackbar.Add(
                        "Cannot place in service: another caller already changed this version's state.",
                        Severity.Warning);
                    await LoadAsync();
                    break;

                case TransitionToInServiceOutcome.RejectedIncompleteWorkflow:
                    // The version has one or more workflows with structural
                    // problems that promotion-time validation refuses. Show
                    // a longer-lived snackbar listing the first few issues
                    // so the user knows what to fix. The full list is in
                    // result.Issues; we cap the message at three to keep it
                    // readable.
                    Snackbar.Add(
                        BuildIncompleteWorkflowMessage(result.Issues),
                        Severity.Warning,
                        config => { config.RequireInteraction = true; });
                    // No LoadAsync — the version is unchanged in the DB.
                    break;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to place version id={VersionId} in service.", versionId);
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _transitioning = false;
        }
    }

    private static string StateLabel(RequestState state) => state switch
    {
        RequestState.Draft => "Draft",
        RequestState.InService => "In Service",
        RequestState.Superseded => "Superseded",
        _ => state.ToString(),
    };

    /// <summary>
    /// Format a workflow-issue list for the rejection snackbar. Caps at
    /// three issues + an "and N more" suffix to keep the message
    /// readable; the user can fix the visible ones, re-try, and see the
    /// next batch if there are more.
    /// </summary>
    private static string BuildIncompleteWorkflowMessage(IReadOnlyList<WorkflowIssue> issues)
    {
        if (issues.Count == 0)
        {
            // Defensive — shouldn't happen but don't surface an empty
            // rejection message.
            return "Cannot place in service: workflow validation failed.";
        }

        var visible = issues.Take(3).Select(DescribeIssue).ToList();
        var summary = string.Join("; ", visible);
        if (issues.Count > 3)
        {
            summary += $" (and {issues.Count - 3} more)";
        }
        return $"Cannot place in service. {summary}.";
    }

    private static string DescribeIssue(WorkflowIssue issue) => issue.Kind switch
    {
        WorkflowIssueKind.NoStartNode =>
            $"workflow '{issue.WorkflowName}' has no Start node",
        WorkflowIssueKind.MissingPath1 =>
            $"workflow '{issue.WorkflowName}' has a node (#{issue.NodeId}) missing its next step",
        WorkflowIssueKind.DecisionMissingPath1 =>
            $"workflow '{issue.WorkflowName}' has a Decision (#{issue.NodeId}) missing its left branch",
        WorkflowIssueKind.DecisionMissingPath2 =>
            $"workflow '{issue.WorkflowName}' has a Decision (#{issue.NodeId}) missing its right branch",
        WorkflowIssueKind.OrphanNode =>
            $"workflow '{issue.WorkflowName}' has an orphan node (#{issue.NodeId})",
        _ => $"workflow '{issue.WorkflowName}' has an unspecified problem",
    };
}
