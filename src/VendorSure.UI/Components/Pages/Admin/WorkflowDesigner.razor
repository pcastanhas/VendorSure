@*
    Workflow Designer — canvas + on-node + and X buttons + dialogs.

    URL: /admin/request-types/{TypeId}/workflows/{WorkflowId}/designer

    Phase 5 / Chunks 4-9:
      - Loads the type + workflow + nodes + block catalog via the repos.
      - Renders breadcrumb back to the type detail page.
      - Shows a read-only banner when the parent version isn't Draft.
      - On first render, instantiates the workflow-designer JS module
        (D3-backed) and mounts it inside <div id="workflow-canvas">.
        The module owns that div completely; Blazor never re-renders
        inside it after first mount.

      Chunk 7 design shift: the canvas is now opinionated, not a dumb
      drop target. Every workflow has a Start node (auto-created in
      WorkflowDefinitionRepository.CreateAsync). The JS module draws
      a + button on every non-terminal node's open slots:
        - one + per Start/Process (centered below)
        - two + per Decision (left = path1, right = path2)
      Clicking a + opens a block-picker dialog. (Originally explored as
      a popover anchored to the click point, but MudBlazor 9's popover
      portal pattern made reliable positioning fragile; a centered
      dialog is mechanically simpler and fine for our 5-power-user
      scale.) When the slot is empty, the picker offers terminals;
      when the slot has an existing child (insert-between), terminals
      are hidden because they can't take a displaced child.

      Inserting a Decision into a non-empty slot opens an extra dialog:
      "which side should <existing child> attach to?" The chosen side
      goes through as InsertChildAsync's DecisionChildSlot parameter.

      Chunk 9: the JS module also draws an X (delete) button in the
      top-left of every node except Start. Clicking X opens a delete
      confirmation dialog whose copy and buttons branch on node type:
        - Decision: single destructive button ("delete and N descendants"
          OR just "delete" if no descendants); no splice option (two
          subtrees can't cleanly merge).
        - Process with descendants: two buttons — splice into parent
          (DeleteAndSpliceAsync) or delete subtree (DeleteSubtreeAsync).
        - Terminal or childless Process: single confirm button.

      A temporary node-list table below the canvas dumps id / type /
      level / paths for cross-reference during dev. Slated for removal
      at end of Phase 5.

    Still ahead: node property editor (Chunk 8 — deferred pending
    user review), promotion-time validation (Chunk 10).
*@

@page "/admin/request-types/{TypeId:int}/workflows/{WorkflowId:int}/designer"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using VendorSure.Domain.RequestTypes
@using VendorSure.Domain.Workflows
@using VendorSure.Services.RequestTypes
@using VendorSure.Services.Workflows

@inject IRequestTypeRepository TypeRepository
@inject IRequestTypeVersionRepository VersionRepository
@inject IWorkflowDefinitionRepository WorkflowRepository
@inject IWorkflowNodeRepository NodeRepository
@inject IBlockCatalogRepository BlockRepository
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ILogger<WorkflowDesigner> Logger

@implements IAsyncDisposable

<PageTitle>@PageTitleText — VendorSure</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
}
else if (_loadError is not null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        @_loadError
        <MudLink Href="/admin/request-types">Back to request types</MudLink>.
    </MudAlert>
}
else
{
    @* Breadcrumb back to the type detail page. The Workflows tab on
       that page is where the admin came from. *@
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h5">@_workflow!.Name</MudText>
        <MudChip T="string"
                 Size="Size.Small"
                 Color="@StateColor(_version!.RequestState)"
                 Variant="Variant.Filled">
            @StateLabel(_version.RequestState)
        </MudChip>
        <MudSpacer />
    </MudStack>

    @if (!IsDraft)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mb-3">
            This version is <strong>@StateLabel(_version.RequestState)</strong> and the workflow is read-only.
            Edits require creating a new Draft version of the parent request type.
        </MudAlert>
    }

    <MudPaper Class="pa-3 mb-4" Elevation="1">
        @* Canvas div: the workflow-designer JS module owns this after
           first mount. Blazor must not re-render inside it. The dashed
           border is a visual cue for empty / pre-mount state. The
           module draws + buttons on each non-terminal node's open
           slots when the workflow is editable (a non-null
           DotNetObjectReference signals editable to the JS side). *@
        <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">
            Canvas
        </MudText>
        <div id="workflow-canvas"
             @key="_workflow.Id"
             style="width: 100%; min-height: 360px; border: 1px dashed var(--mud-palette-divider); border-radius: 4px; overflow: auto;">
        </div>
    </MudPaper>

    @* Block-picker dialog. Originally explored as a MudPopover anchored
       to the click point, but MudBlazor 9's popover portal pattern made
       reliable positioning fragile. A centered dialog is less precious
       UX but rock-solid mechanically and perfectly fine for a 5-power-
       user internal tool. The variant string differs between add (empty
       slot) and insert (slot has an existing child) so the title is
       honest about what's about to happen. *@
    <MudDialog @bind-Visible="_pickerOpen"
               Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">
                @(_pickerSlotEmpty ? "Add child" : "Insert child")
            </MudText>
        </TitleContent>
        <DialogContent>
            @if (_pickerSlotEmpty)
            {
                @* Terminals only offered when slot is empty — they have no
                   children and can't take a displaced child as one. *@
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Terminals</MudText>
                @foreach (var t in TerminalPickerItems)
                {
                    <div class="picker-row pa-2 mb-1 mud-paper mud-paper-outlined"
                         @onclick="@(() => OnPickerSelect(t.NodeTypeId, null))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <div style="width: 14px; height: 14px; border-radius: 3px;
                                        background-color: @t.Color;
                                        border: 1px solid rgba(0,0,0,0.15);"></div>
                            <MudText Typo="Typo.body2">@t.Label</MudText>
                        </MudStack>
                    </div>
                }
            }

            @{
                var processBlocks = _blocks.Where(b => b.NodeTypeId == WorkflowNodeTypeIds.Process).ToList();
                var decisionBlocks = _blocks.Where(b => b.NodeTypeId == WorkflowNodeTypeIds.Decision).ToList();
            }

            @if (processBlocks.Count > 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 mt-2">Process blocks</MudText>
                @foreach (var b in processBlocks)
                {
                    <div class="picker-row pa-2 mb-1 mud-paper mud-paper-outlined"
                         @onclick="@(() => OnPickerSelect(b.NodeTypeId, b.Id))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <div style="width: 14px; height: 14px; border-radius: 3px;
                                        background-color: @(b.Color ?? DefaultColorFor(b.NodeTypeId));
                                        border: 1px solid rgba(0,0,0,0.15);"></div>
                            <MudText Typo="Typo.body2">@b.Description</MudText>
                        </MudStack>
                    </div>
                }
            }

            @if (decisionBlocks.Count > 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 mt-2">Decision blocks</MudText>
                @foreach (var b in decisionBlocks)
                {
                    <div class="picker-row pa-2 mb-1 mud-paper mud-paper-outlined"
                         @onclick="@(() => OnPickerSelect(b.NodeTypeId, b.Id))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <div style="width: 14px; height: 14px; border-radius: 3px;
                                        background-color: @(b.Color ?? DefaultColorFor(b.NodeTypeId));
                                        border: 1px solid rgba(0,0,0,0.15);"></div>
                            <MudText Typo="Typo.body2">@b.Description</MudText>
                        </MudStack>
                    </div>
                }
            }

            @if (_blocks.Count == 0 && !_pickerSlotEmpty)
            {
                @* Insert-between with no Process or Decision blocks to offer.
                   Terminals are excluded. So there's literally nothing the
                   user can pick — surface that explicitly. *@
                <MudText Typo="Typo.caption" Class="mud-text-disabled mt-2">
                    No blocks available for splicing here. Either add an empty
                    slot first, or seed <code>dbo.block_catalog</code>.
                </MudText>
            }
            else if (_blocks.Count == 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-disabled mt-2">
                    No Process or Decision blocks in the catalog yet. Seed
                    <code>dbo.block_catalog</code> to add some.
                </MudText>
            }
        </DialogContent>
    </MudDialog>

    @* Decision-which-side dialog. Opened when the user picks a Decision
       block from the picker AND the slot they clicked on is non-empty
       (insert-between case). The user must choose whether the displaced
       existing child goes on path1 (left) or path2 (right) of the new
       Decision. Cancel just closes — no node is created. *@
    <MudDialog @bind-Visible="_decisionDialogOpen"
               Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">Inserting a Decision</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="mb-3">
                Which side of the new Decision should
                <strong>@_pendingDisplacedChildLabel</strong>
                attach to? The other side will start empty for you to fill in.
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="OnDecisionSideCanceled">Cancel</MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Outlined"
                       OnClick="@(() => OnDecisionSideChosen(1))">
                Left (path 1)
            </MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="@(() => OnDecisionSideChosen(2))">
                Right (path 2)
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* Delete confirmation dialog. Three variants in one shape:
       - Decision: single warning button + cancel ("delete both subtrees").
       - Process with descendants: two buttons (splice into parent vs
         delete this and N descendants) + cancel.
       - Terminal OR Process with no children: single delete button +
         cancel ("delete this node?").
       Branches on _pendingDeleteIsDecision and _pendingDeleteAllowsSplice. *@
    <MudDialog @bind-Visible="_deleteDialogOpen"
               Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">
                Delete @_pendingDeleteLabel node?
            </MudText>
        </TitleContent>
        <DialogContent>
            @if (_pendingDeleteIsDecision)
            {
                @if (_pendingDeleteDescendantCount > 0)
                {
                    <MudText Typo="Typo.body2" Class="mb-2">
                        This Decision will be deleted along with
                        <strong>both subtrees</strong>
                        (@_pendingDeleteDescendantCount total descendant@(_pendingDeleteDescendantCount == 1 ? "" : "s")).
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mb-2">
                        This Decision has no descendants yet and will be removed.
                    </MudText>
                }
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Decisions can't be spliced — the two branches have no clean way to merge.
                </MudText>
            }
            else if (_pendingDeleteAllowsSplice)
            {
                <MudText Typo="Typo.body2" Class="mb-2">
                    This @_pendingDeleteLabel node has
                    <strong>@_pendingDeleteDescendantCount descendant@(_pendingDeleteDescendantCount == 1 ? "" : "s")</strong>.
                    What should happen to them?
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.body2">
                    Delete this @_pendingDeleteLabel node?
                </MudText>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="OnDeleteCanceled">Cancel</MudButton>

            @if (_pendingDeleteAllowsSplice)
            {
                @* Process with descendants: two destructive options. *@
                <MudButton OnClick="OnConfirmSplice"
                           Color="Color.Default"
                           Variant="Variant.Outlined">
                    Keep them — splice into parent
                </MudButton>
                <MudButton OnClick="OnConfirmDeleteSubtree"
                           Color="Color.Error"
                           Variant="Variant.Filled">
                    Delete this and @_pendingDeleteDescendantCount @(_pendingDeleteDescendantCount == 1 ? "descendant" : "descendants")
                </MudButton>
            }
            else
            {
                @* Decision OR leaf delete: single destructive button. *@
                <MudButton OnClick="OnConfirmDeleteSubtree"
                           Color="Color.Error"
                           Variant="Variant.Filled">
                    @if (_pendingDeleteIsDecision && _pendingDeleteDescendantCount > 0)
                    {
                        <text>Delete Decision and @_pendingDeleteDescendantCount @(_pendingDeleteDescendantCount == 1 ? "descendant" : "descendants")</text>
                    }
                    else
                    {
                        <text>Delete</text>
                    }
                </MudButton>
            }
        </DialogActions>
    </MudDialog>

    @* --- TEMPORARY: node-list test affordance ----------------------------
       Provides a textual readout of the workflow's nodes so we can
       eyeball repository behavior (renumber correctness, path FKs,
       start_node_id) while the canvas is being built out in Chunks
       5-10. Tagged for removal at end of Phase 5 when the canvas
       fully replaces this. ---------------------------------------------- *@
    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">
                Nodes (temporary readout — removed at end of Phase 5)
            </MudText>
            <MudSpacer />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                start_node_id =
                @if (_workflow.StartNodeId is int startId)
                {
                    <code>@startId</code>
                }
                else
                {
                    <em>null</em>
                }
            </MudText>
        </MudStack>

        @if (_nodes.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-disabled">
                This workflow has no nodes yet.
            </MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                <thead>
                    <tr>
                        <th>id</th>
                        <th>node type</th>
                        <th>block id</th>
                        <th>level</th>
                        <th>path1</th>
                        <th>path2</th>
                        <th>prompt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in _nodes)
                    {
                        <tr>
                            <td><code>@n.Id</code></td>
                            <td>@NodeTypeLabel(n.NodeTypeId)</td>
                            <td>
                                @if (n.BlockCatalogId is int b)
                                {
                                    <code>@b</code>
                                }
                                else
                                {
                                    <span class="mud-text-disabled">—</span>
                                }
                            </td>
                            <td><code>@n.ExecutionLevel</code></td>
                            <td>
                                @if (n.Path1NodeId is int p1)
                                {
                                    <code>→ @p1</code>
                                }
                                else
                                {
                                    <span class="mud-text-disabled">—</span>
                                }
                            </td>
                            <td>
                                @if (n.Path2NodeId is int p2)
                                {
                                    <code>→ @p2</code>
                                }
                                else
                                {
                                    <span class="mud-text-disabled">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(n.PromptText))
                                {
                                    <span class="mud-text-secondary">@n.PromptText</span>
                                }
                                else
                                {
                                    <span class="mud-text-disabled">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>
}

@code {
    [Parameter] public int TypeId { get; set; }
    [Parameter] public int WorkflowId { get; set; }

    private RequestType? _type;
    private RequestTypeVersion? _version;
    private WorkflowDefinition? _workflow;
    private IReadOnlyList<WorkflowNode> _nodes = Array.Empty<WorkflowNode>();
    private IReadOnlyList<BlockCatalog> _blocks = Array.Empty<BlockCatalog>();
    private List<BreadcrumbItem> _breadcrumbs = new();

    private bool _loading = true;
    private string? _loadError;

    // JS interop state. The module reference is resolved on first render
    // (after the canvas div exists in the DOM) and kept for the lifetime
    // of the page so re-mounts after edits don't have to reimport.
    // _dotNetRef is the JS-callable handle for OnPlusClickedAsync; it's
    // long-lived and disposed alongside the module.
    private IJSObjectReference? _module;
    private DotNetObjectReference<WorkflowDesigner>? _dotNetRef;
    private bool _mounted;
    private const string CanvasSelector = "#workflow-canvas";

    // Block-picker dialog state. _pickerSlotEmpty controls whether
    // terminals are offered in the picker (terminals can't be
    // inserted-between because they have no children to take a
    // displaced child).
    private bool _pickerOpen;
    private int _pickerParentId;
    private int _pickerParentSlot;
    private bool _pickerSlotEmpty;

    // Decision-which-side dialog state. When the picker selection is a
    // Decision AND the parent's slot is non-empty (insert-between case),
    // we need to ask the user which Decision slot inherits the displaced
    // child. The dialog reads this struct; OnDecisionSideChosen reads
    // it back to call InsertChildAsync with the right DecisionChildSlot.
    private bool _decisionDialogOpen;
    private int? _pendingDecisionBlockId;
    private string _pendingDisplacedChildLabel = string.Empty;

    // Delete confirmation dialog state. Branches on the node type and
    // descendant count to show the right confirm copy and action
    // buttons. OnDeleteClickedAsync (from JS) populates these and opens
    // the dialog; OnConfirmSplice / OnConfirmDeleteSubtree / OnDeleteCanceled
    // close it.
    private bool _deleteDialogOpen;
    private int _pendingDeleteNodeId;
    private string _pendingDeleteLabel = string.Empty;
    private int _pendingDeleteDescendantCount;
    private bool _pendingDeleteAllowsSplice;   // Process with > 0 descendants
    private bool _pendingDeleteIsDecision;      // Decision (no splice option)

    private bool IsDraft => _version?.RequestState == RequestState.Draft;
    private string PageTitleText => _workflow is null ? "Workflow Designer" : _workflow.Name;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        // If the user navigates from one workflow designer to another
        // (same component instance, different WorkflowId), we want the
        // canvas re-mounted with the new graph. The @key on the canvas
        // div makes Blazor tear down the old div, but the JS module
        // doesn't know about that — re-flag for mount so OnAfterRender
        // will call mount() again with the new payload.
        _mounted = false;
        try
        {
            // Resolve in dependency order: workflow → version (via workflow's
            // version id) → type (via version's type id). If anything is
            // missing or mismatched against the URL, surface a single
            // "not found" with the same affordance regardless of which
            // entity is missing. The fine-grained reason isn't useful to
            // the user — they shared a bad URL or the entity got deleted.
            _workflow = await WorkflowRepository.GetByIdAsync(WorkflowId);
            if (_workflow is null)
            {
                _loadError = $"Workflow id={WorkflowId} not found.";
                return;
            }

            _version = await VersionRepository.GetByIdAsync(_workflow.RequestTypeVersionId);
            if (_version is null)
            {
                _loadError = $"Workflow id={WorkflowId} references a missing version.";
                return;
            }

            _type = await TypeRepository.GetByIdAsync(_version.RequestTypeId);
            if (_type is null)
            {
                _loadError = $"Workflow id={WorkflowId} references a missing request type.";
                return;
            }

            // URL-vs-data sanity check: did the caller's TypeId actually
            // match the workflow's type? If not, the URL is malformed
            // (someone hand-edited it or shared a stale link). Treat as
            // not found rather than silently redirecting — the breadcrumbs
            // would be misleading otherwise.
            if (_type.Id != TypeId)
            {
                _loadError =
                    $"Workflow id={WorkflowId} belongs to request type id={_type.Id}, " +
                    $"but the URL says id={TypeId}.";
                return;
            }

            _nodes = await NodeRepository.ListByWorkflowIdAsync(WorkflowId);

            // Block catalog drives the picker dialog options. Loading it
            // here keeps page state hydrated before the dialog opens so
            // there's no fetch delay when the user clicks +. The catalog
            // is small (a handful of rows even at production scale).
            _blocks = await BlockRepository.ListActiveAsync();

            _breadcrumbs = new()
            {
                new BreadcrumbItem("Request Types", href: "/admin/request-types"),
                new BreadcrumbItem(_type.Name, href: $"/admin/request-types/{_type.Id}"),
                new BreadcrumbItem(_workflow.Name, href: null, disabled: true),
            };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Failed to load workflow designer for type={TypeId} workflow={WorkflowId}.",
                TypeId, WorkflowId);
            _loadError = $"Failed to load: {ex.Message}";
            Snackbar.Add("Failed to load workflow designer.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The canvas div only exists in the DOM after _loading flips to
        // false AND the workflow loaded cleanly. We could be in any of
        // three states on a given render: still loading, error, or ready.
        // Only mount when ready, and only once — if the page state
        // changes during this Phase 5 chunk, we explicitly don't re-mount
        // (the canvas would need an update() call instead, landing in a
        // later chunk).
        if (_loading || _loadError is not null || _workflow is null)
        {
            return;
        }

        if (_mounted)
        {
            return;
        }

        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/workflow-designer.js");

            // Only allocate the .NET callback when the workflow is
            // editable. Read-only views don't need drop support, and not
            // passing the ref keeps the JS module from wiring up listeners
            // it would never use (see attachDropListeners' guard).
            if (IsDraft && _dotNetRef is null)
            {
                _dotNetRef = DotNetObjectReference.Create(this);
            }

            var payload = BuildGraphPayload();
            await _module.InvokeVoidAsync("mount", CanvasSelector, payload, _dotNetRef);
            _mounted = true;
        }
        catch (JSDisconnectedException)
        {
            // Circuit dropped before mount completed; nothing to clean up.
        }
        catch (Exception ex)
        {
            Logger.LogError(ex,
                "Failed to mount workflow-designer JS module for workflow={WorkflowId}.",
                WorkflowId);
            Snackbar.Add(
                "Failed to render workflow canvas. Reload the page to retry.",
                Severity.Error);
        }
    }

    // Shape the WorkflowNode list into the JS-friendly form the module
    // expects. The module wants flat objects with camelCase fields plus
    // a separate `edges` array derived from path1/path2 FKs. Doing the
    // transform in C# keeps the JS module dumb and easy to reason about.
    private object BuildGraphPayload()
    {
        // The JS module needs each node's path FK values to decide where
        // the + buttons should go (empty slot → below the parent,
        // non-empty slot → on the edge between parent and child). Emit
        // them alongside the other fields rather than reconstructing
        // from the edge list on the JS side.
        var nodes = _nodes.Select(n => new
        {
            id = n.Id,
            nodeTypeId = n.NodeTypeId,
            blockCatalogId = n.BlockCatalogId,
            executionLevel = n.ExecutionLevel,
            path1NodeId = n.Path1NodeId,
            path2NodeId = n.Path2NodeId,
            promptText = n.PromptText,
        }).ToArray();

        var edges = new List<object>();
        foreach (var n in _nodes)
        {
            if (n.Path1NodeId is int p1)
            {
                edges.Add(new { sourceId = n.Id, targetId = p1, kind = "path1" });
            }
            if (n.Path2NodeId is int p2)
            {
                edges.Add(new { sourceId = n.Id, targetId = p2, kind = "path2" });
            }
        }

        return new { nodes, edges };
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", CanvasSelector);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone; the browser disposed everything for us.
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex,
                    "Error disposing workflow-designer JS module for workflow={WorkflowId}.",
                    WorkflowId);
            }
        }

        // Dispose the .NET callback reference whether or not the JS side
        // managed to clean up. Holding it would leak the page across
        // GC cycles since the JS side ostensibly still has a reference.
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    /// <summary>
    /// Picker entries for the three terminal node types (Approved /
    /// Rejected / Cancelled). Offered only when the slot being filled
    /// is empty (terminals have no out-edges, so they can't accept a
    /// displaced child in the insert-between case).
    /// </summary>
    private static readonly TerminalPickerItem[] TerminalPickerItems = new[]
    {
        new TerminalPickerItem(WorkflowNodeTypeIds.Approved,  "Approved",  "#43a047"),
        new TerminalPickerItem(WorkflowNodeTypeIds.Rejected,  "Rejected",  "#e53935"),
        new TerminalPickerItem(WorkflowNodeTypeIds.Cancelled, "Cancelled", "#757575"),
    };

    private readonly record struct TerminalPickerItem(int NodeTypeId, string Label, string Color);

    private static string DefaultColorFor(int nodeTypeId) => nodeTypeId switch
    {
        WorkflowNodeTypeIds.Process => "#1976d2",
        WorkflowNodeTypeIds.Decision => "#ffa726",
        _ => "#9e9e9e",
    };

    /// <summary>
    /// Invoked from JS when the user clicks a + button on the canvas.
    /// Captures the click context (which parent, which slot, whether
    /// the slot is empty) and opens the block picker. The JS module
    /// also sends viewport pixel coords for the click — we accept
    /// them for forward-compatibility (a future popover variant
    /// could use them) but the current MudDialog picker is centered
    /// so the coordinates are unused.
    /// </summary>
    [JSInvokable]
    public Task OnPlusClickedAsync(int parentNodeId, int parentSlot, bool slotEmpty, int clientX, int clientY)
    {
        _ = clientX;
        _ = clientY;
        _pickerParentId = parentNodeId;
        _pickerParentSlot = parentSlot;
        _pickerSlotEmpty = slotEmpty;
        _pickerOpen = true;

        StateHasChanged();
        return Task.CompletedTask;
    }

    /// <summary>
    /// User picked an option from the picker dialog. Two paths:
    ///  - Decision new-node into a non-empty slot: open the
    ///    Decision-which-side dialog and wait for the user.
    ///  - All other cases: call InsertChildAsync directly.
    /// </summary>
    private async Task OnPickerSelect(int nodeTypeId, int? blockCatalogId)
    {
        _pickerOpen = false;

        if (nodeTypeId == WorkflowNodeTypeIds.Decision && !_pickerSlotEmpty)
        {
            // Need to ask which Decision slot inherits the displaced
            // child before we can insert. Stash the block id, look up the
            // displaced child's label for the dialog copy, and open it.
            _pendingDecisionBlockId = blockCatalogId;
            _pendingDisplacedChildLabel = LookupDisplacedChildLabel();
            _decisionDialogOpen = true;
            StateHasChanged();
            return;
        }

        await InsertChildAsync(nodeTypeId, blockCatalogId, decisionChildSlot: null);
    }

    /// <summary>
    /// User chose which side of the inserted Decision should inherit the
    /// displaced child. Closes the dialog, then performs the insert.
    /// </summary>
    private async Task OnDecisionSideChosen(int decisionChildSlot)
    {
        _decisionDialogOpen = false;
        var blockId = _pendingDecisionBlockId;
        _pendingDecisionBlockId = null;
        await InsertChildAsync(WorkflowNodeTypeIds.Decision, blockId, decisionChildSlot);
    }

    private void OnDecisionSideCanceled()
    {
        _decisionDialogOpen = false;
        _pendingDecisionBlockId = null;
        _pendingDisplacedChildLabel = string.Empty;
    }

    /// <summary>
    /// Looks up the displaced child's display label for the
    /// Decision-which-side dialog copy. The child id is whichever path FK
    /// the parent currently holds in <see cref="_pickerParentSlot"/>.
    /// Best-effort: if we can't find it (shouldn't happen — the slot was
    /// non-empty when JS sent us here) we fall back to "the existing node".
    /// </summary>
    private string LookupDisplacedChildLabel()
    {
        var parent = _nodes.FirstOrDefault(n => n.Id == _pickerParentId);
        if (parent is null) return "the existing node";

        var childId = _pickerParentSlot == 1 ? parent.Path1NodeId : parent.Path2NodeId;
        if (childId is null) return "the existing node";

        var child = _nodes.FirstOrDefault(n => n.Id == childId.Value);
        if (child is null) return $"node #{childId.Value}";

        return $"{NodeTypeLabel(child.NodeTypeId)} #{child.Id}";
    }

    /// <summary>
    /// Invoked from JS when the user clicks the X (delete) button on a
    /// node. Walks the in-memory _nodes list to count descendants,
    /// then opens the delete confirmation dialog with copy and buttons
    /// appropriate for the node's type.
    /// </summary>
    [JSInvokable]
    public Task OnDeleteClickedAsync(int nodeId)
    {
        var node = _nodes.FirstOrDefault(n => n.Id == nodeId);
        if (node is null)
        {
            // Stale page — node deleted by another user, or page hasn't
            // refreshed. Reload silently rather than show an error.
            return Task.CompletedTask;
        }

        if (node.NodeTypeId == WorkflowNodeTypeIds.Start)
        {
            // Defensive — JS doesn't render an X on Start, but if a
            // stale render or future bug sent one through, refuse.
            Snackbar.Add("Start nodes cannot be deleted.", Severity.Warning);
            return Task.CompletedTask;
        }

        _pendingDeleteNodeId = nodeId;
        _pendingDeleteLabel = NodeTypeLabel(node.NodeTypeId);
        _pendingDeleteDescendantCount = CountDescendants(nodeId);
        _pendingDeleteIsDecision = node.NodeTypeId == WorkflowNodeTypeIds.Decision;

        // Splice option is offered for Process nodes that actually have
        // descendants. Process without descendants → plain confirm (no
        // splice button needed, the delete is straightforward).
        _pendingDeleteAllowsSplice =
            node.NodeTypeId == WorkflowNodeTypeIds.Process
            && _pendingDeleteDescendantCount > 0;

        _deleteDialogOpen = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    /// <summary>
    /// Counts descendants reachable from <paramref name="nodeId"/> via
    /// path1/path2, using the in-memory _nodes list. Doesn't include
    /// the node itself. Matches what DeleteSubtreeAsync will report,
    /// so the dialog count and the repo result line up.
    /// </summary>
    private int CountDescendants(int nodeId)
    {
        var nodesById = _nodes.ToDictionary(n => n.Id);
        var visited = new HashSet<int>();
        var stack = new Stack<int>();
        stack.Push(nodeId);
        while (stack.Count > 0)
        {
            var id = stack.Pop();
            if (!visited.Add(id)) continue;
            if (!nodesById.TryGetValue(id, out var n)) continue;
            if (n.Path1NodeId is int p1) stack.Push(p1);
            if (n.Path2NodeId is int p2) stack.Push(p2);
        }
        // visited includes the root itself; subtract 1 for descendants.
        return Math.Max(0, visited.Count - 1);
    }

    private void OnDeleteCanceled()
    {
        _deleteDialogOpen = false;
        _pendingDeleteNodeId = 0;
        _pendingDeleteLabel = string.Empty;
        _pendingDeleteDescendantCount = 0;
        _pendingDeleteAllowsSplice = false;
        _pendingDeleteIsDecision = false;
    }

    private async Task OnConfirmSplice()
    {
        var nodeId = _pendingDeleteNodeId;
        _deleteDialogOpen = false;
        try
        {
            var outcome = await NodeRepository.DeleteAndSpliceAsync(nodeId);
            await ApplyDeleteOutcomeAsync(outcome);
        }
        catch (ArgumentException ex)
        {
            // Caller-bug per the repo's contract. Shouldn't happen — we
            // only show the splice button for Process with descendants.
            Logger.LogError(ex,
                "DeleteAndSpliceAsync rejected the request: nodeId={NodeId}.",
                nodeId);
            Snackbar.Add("Could not splice — internal error.", Severity.Error);
        }
    }

    private async Task OnConfirmDeleteSubtree()
    {
        var nodeId = _pendingDeleteNodeId;
        _deleteDialogOpen = false;

        var result = await NodeRepository.DeleteSubtreeAsync(nodeId);
        switch (result.Outcome)
        {
            case DeleteSubtreeOutcome.Deleted:
                await RefreshAfterEditAsync();
                var n = result.DescendantsDeleted;
                Snackbar.Add(
                    n == 0
                        ? "Node deleted."
                        : $"Deleted node and {n} descendant{(n == 1 ? "" : "s")}.",
                    Severity.Success);
                break;

            case DeleteSubtreeOutcome.RejectedNodeNotFound:
                Snackbar.Add("Node no longer exists. Reload the page.", Severity.Warning);
                break;

            case DeleteSubtreeOutcome.RejectedNotDraft:
                Snackbar.Add(
                    "Version is no longer Draft. Reload the page.",
                    Severity.Warning);
                break;

            case DeleteSubtreeOutcome.RejectedIsStart:
                // Defensive — JS doesn't render an X on Start.
                Snackbar.Add("Start nodes cannot be deleted.", Severity.Warning);
                break;

            default:
                Snackbar.Add("Could not delete node.", Severity.Error);
                break;
        }
    }

    private async Task ApplyDeleteOutcomeAsync(DeleteAndSpliceOutcome outcome)
    {
        switch (outcome)
        {
            case DeleteAndSpliceOutcome.Deleted:
                await RefreshAfterEditAsync();
                Snackbar.Add("Node spliced out.", Severity.Success);
                break;

            case DeleteAndSpliceOutcome.RejectedNodeNotFound:
                Snackbar.Add("Node no longer exists. Reload the page.", Severity.Warning);
                break;

            case DeleteAndSpliceOutcome.RejectedNotDraft:
                Snackbar.Add(
                    "Version is no longer Draft. Reload the page.",
                    Severity.Warning);
                break;

            case DeleteAndSpliceOutcome.RejectedIsStart:
                Snackbar.Add("Start nodes cannot be deleted.", Severity.Warning);
                break;

            default:
                Snackbar.Add("Could not splice node.", Severity.Error);
                break;
        }
    }

    /// <summary>
    /// Common post-edit work: reload node list, re-mount the canvas
    /// with the updated graph, and force a re-render of the readout
    /// table. Both InsertChildAsync's success branch and the delete
    /// handlers share this.
    /// </summary>
    private async Task RefreshAfterEditAsync()
    {
        _nodes = await NodeRepository.ListByWorkflowIdAsync(WorkflowId);
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync(
                    "mount", CanvasSelector, BuildGraphPayload(), _dotNetRef);
            }
            catch (JSDisconnectedException)
            {
                // User navigated away. Nothing to do.
            }
        }
        StateHasChanged();
    }

    private async Task InsertChildAsync(int nodeTypeId, int? blockCatalogId, int? decisionChildSlot)
    {
        if (_workflow is null)
        {
            // Defensive: the page is in a bad state.
            return;
        }

        var request = new InsertChildRequest(
            ParentNodeId: _pickerParentId,
            ParentSlot: _pickerParentSlot,
            NodeTypeId: nodeTypeId,
            BlockCatalogId: blockCatalogId,
            DecisionChildSlot: decisionChildSlot);

        InsertChildResult result;
        try
        {
            result = await NodeRepository.InsertChildAsync(request);
        }
        catch (ArgumentException ex)
        {
            // Caller-bug from our perspective (UI sent something the repo
            // refuses). Log and surface a generic error — these aren't
            // user-facing in normal flow.
            Logger.LogError(ex,
                "InsertChildAsync rejected the request: parentId={ParentId}, slot={Slot}, type={Type}, block={Block}, decisionChildSlot={DCS}.",
                _pickerParentId, _pickerParentSlot, nodeTypeId, blockCatalogId, decisionChildSlot);
            Snackbar.Add("Could not add node — internal error.", Severity.Error);
            return;
        }

        switch (result.Outcome)
        {
            case InsertChildOutcome.Inserted:
                await RefreshAfterEditAsync();
                Snackbar.Add($"Added {NodeTypeLabel(nodeTypeId)} node.", Severity.Success);
                break;

            case InsertChildOutcome.RejectedParentNotFound:
                Snackbar.Add("Parent node no longer exists. Reload the page.", Severity.Warning);
                break;

            case InsertChildOutcome.RejectedNotDraft:
                Snackbar.Add(
                    "Version is no longer Draft. Reload the page.",
                    Severity.Warning);
                break;

            case InsertChildOutcome.RejectedParentIsTerminal:
                // UI shouldn't have rendered a + button here. Surface
                // generically; the page reload below will fix the state.
                Snackbar.Add("Cannot add a child to a terminal node.", Severity.Warning);
                break;

            case InsertChildOutcome.RejectedInvalidShape:
                Snackbar.Add(
                    "Could not add node: invalid type/block combination.",
                    Severity.Warning);
                break;

            default:
                Snackbar.Add("Could not add node.", Severity.Error);
                break;
        }
    }

    private static string NodeTypeLabel(int nodeTypeId) => nodeTypeId switch
    {
        WorkflowNodeTypeIds.Start => "Start",
        WorkflowNodeTypeIds.Process => "Process",
        WorkflowNodeTypeIds.Decision => "Decision",
        WorkflowNodeTypeIds.Approved => "Approved",
        WorkflowNodeTypeIds.Rejected => "Rejected",
        WorkflowNodeTypeIds.Cancelled => "Cancelled",
        _ => $"unknown ({nodeTypeId})",
    };

    private static string StateLabel(RequestState state) => state switch
    {
        RequestState.Draft => "Draft",
        RequestState.InService => "In Service",
        RequestState.Superseded => "Superseded",
        _ => state.ToString(),
    };

    private static Color StateColor(RequestState state) => state switch
    {
        RequestState.Draft => Color.Primary,
        RequestState.InService => Color.Success,
        RequestState.Superseded => Color.Default,
        _ => Color.Default,
    };
}
