@using VendorSure.Domain.Documents

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@TitleText</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name"
                          Label="Name"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Error="@NameIsInvalid"
                          ErrorText="Name is required."
                          MaxLength="100"
                          HelperText="Shown to submitters as a label on the upload slot." />

            <MudTextField @bind-Value="_fileTypeRequired"
                          Label="File type hint (optional)"
                          Variant="Variant.Outlined"
                          MaxLength="10"
                          HelperText="Display-only hint such as 'pdf' or 'docx'. Not enforced at upload." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Disabled="@NameIsInvalid">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>The doc type being edited. <c>Id == 0</c> means "create new".</summary>
    [Parameter, EditorRequired] public DocumentType DocType { get; set; } = default!;

    private string _name = string.Empty;
    private string _fileTypeRequired = string.Empty;

    private bool IsCreate => DocType.Id == 0;
    private string TitleText => IsCreate ? "New document type" : $"Edit {DocType.Name}";

    private bool NameIsInvalid => string.IsNullOrWhiteSpace(_name);

    protected override void OnInitialized()
    {
        _name = DocType.Name;
        _fileTypeRequired = DocType.FileTypeRequired ?? string.Empty;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Save()
    {
        if (NameIsInvalid) return;

        var trimmedFt = _fileTypeRequired.Trim();
        var result = new DocumentType
        {
            Id = DocType.Id,
            Name = _name.Trim(),
            FileTypeRequired = string.IsNullOrEmpty(trimmedFt) ? null : trimmedFt,
        };
        MudDialog.Close(DialogResult.Ok(result));
    }
}
